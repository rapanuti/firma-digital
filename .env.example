# =========================================================================
# Plantilla de variables de entorno. Copiar a .env y ajustar.
#   cp .env.example .env
# El archivo .env NUNCA debe versionarse (está en .gitignore).
# =========================================================================

# --- Django ---
# Generar una clave nueva con:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
DJANGO_SECRET_KEY=cambia-esta-clave
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Base de datos (PostgreSQL) ---
# Formato: postgres://USUARIO:CLAVE@HOST:PUERTO/NOMBRE_BD
DATABASE_URL=postgres://oanzola@localhost:5432/firma_digital

# --- Verificación pública (QR) ---
# Dominio público base para los enlaces de verificación del código QR.
VERIFICATION_BASE_URL=http://localhost:8000

# --- Límites de subida ---
MAX_PDF_SIZE_MB=20
MAX_IMAGE_SIZE_MB=5

# --- Producción (activar solo bajo HTTPS) ---
DJANGO_SECURE_SSL=False
# DJANGO_CSRF_TRUSTED_ORIGINS=https://midominio.com
